# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# Required: Django secret key (generate e.g. with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
# If the key contains # or other special characters, wrap the whole value in double quotes:
# SECRET_KEY="...your-key..."
SECRET_KEY=your-secret-key-here

# Optional: set to False in production
# DEBUG=True

# Comma-separated hostnames (no spaces). Defaults match coderr.manuelgiehl.com + api subdomain.
# ALLOWED_HOSTS=127.0.0.1,localhost,testserver,apicoderr.manuelgiehl.com,coderr.manuelgiehl.com

# Browser origins allowed to call the API when DEBUG=False (comma-separated, include scheme).
# CORS_ALLOWED_ORIGINS=https://coderr.manuelgiehl.com

# For Django admin / CSRF over HTTPS (comma-separated).
# CSRF_TRUSTED_ORIGINS=https://coderr.manuelgiehl.com,https://apicoderr.manuelgiehl.com

# On Ionos/nginx behind TLS termination: uncomment so Django sees HTTPS correctly.
# USE_X_FORWARDED_PROTO=True
